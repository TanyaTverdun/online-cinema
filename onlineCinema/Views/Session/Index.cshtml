@model IEnumerable<onlineCinema.ViewModels.SessionScheduleViewModel>

@{
    ViewData["Title"] = "Розклад сеансів";
}

<div class="container mt-5">
    <h2 class="mb-5 text-center text-uppercase fw-bold schedule-title text-white">Розклад сеансів</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-dark text-center border-secondary py-5">
            <i class="bi bi-calendar-x fs-1 d-block mb-3 text-secondary"></i>
            <span class="fs-5 text-secondary">Сеансів на сьогодні поки немає. Зайдіть пізніше!</span>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var session in Model)
            {
                <div class="col">
                    <div class="card h-100 movie-card border-0 bg-dark shadow-lg">
                        <div class="position-relative overflow-hidden">
                            @* Виправлено вивід картинки *@
                            <img src="@(string.IsNullOrWhiteSpace(session.MoviePoster) ? "https://via.placeholder.com/400x600?text=No+Poster" : session.MoviePoster)"
                                 class="card-img-top poster-img"
                                 alt="@session.MovieTitle" />
                            <div class="price-tag px-3 py-1">@session.Price грн</div>
                        </div>

                        <div class="card-body d-flex flex-column text-white">
                            <h5 class="card-title fw-bold text-uppercase mb-3">@session.MovieTitle</h5>

                            <div class="session-info mb-4">
                                <div class="d-flex align-items-center mb-2 text-white-50 small text-uppercase">
                                    <i class="bi bi-geo-alt-fill me-2 text-danger"></i>
                                    <strong>@session.HallName</strong>
                                </div>
                                <div class="d-flex align-items-center text-white-50 small">
                                    <i class="bi bi-clock-fill me-2 text-danger"></i>
                                    <span>@session.StartTime • @session.StartDate</span>
                                </div>
                            </div>

                            <div class="mt-auto">
                                <a asp-controller="Booking"
                                   asp-action="SelectSeat"
                                   asp-route-sessionId="@session.SessionId"
                                   class="btn btn-danger btn-glow w-100 fw-bold text-uppercase py-2">
                                    <i class="bi bi-ticket-perforated me-2"></i> Купити квиток
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>