<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - onlineCinema</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.2/dist/lux/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/onlineCinema.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/layout-styles.css" asp-append-version="true" />
</head>
<body class="bg-black text-white d-flex flex-column min-vh-100">

    <header>
        <nav class="navbar navbar-expand-lg header-bg py-3 border-bottom border-secondary border-opacity-25">
            <div class="container-fluid px-4">

                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <div class="logo-icon d-flex align-items-center justify-content-center bg-danger rounded-1 p-1">
                        <i class="bi bi-film fs-4 text-white"></i>
                    </div>
                    <div class="fw-bold fs-4 lh-1 text-uppercase" style="letter-spacing: 1px;">
                        <span class="text-white">Online</span><span class="text-danger">Cinema</span>
                    </div>
                </a>

                <button class="navbar-toggler border-white" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">

                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-lg-4">
                        <li class="nav-item">
                            <a class="nav-link nav-custom-link" asp-controller="Movies" asp-action="Index">Movies</a>
                        </li>
                        <li class="nav-item">
                            @* Контролер Session для твого розкладу *@
                            <a class="nav-link nav-custom-link text-uppercase fw-semibold" asp-controller="Session" asp-action="Index">Schedule</a>
                        </li>
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-custom-link" asp-controller="Profile" asp-action="MyProfile">My Profile</a>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-3">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <div class="user-badge d-flex align-items-center gap-3 px-3 py-1 rounded-pill bg-dark border border-secondary">
                                <span class="fw-bold small text-uppercase text-white">@User.Identity.Name</span>
                                <div class="user-avatar rounded-circle bg-danger d-flex align-items-center justify-content-center" style="width: 30px; height: 30px;">
                                    <i class="bi bi-person-fill text-white"></i>
                                </div>
                            </div>
                            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                <button type="submit" class="btn btn-link p-0 text-secondary" title="Logout">
                                    <i class="bi bi-box-arrow-right fs-4"></i>
                                </button>
                            </form>
                        }
                        else
                        {
                            <div class="d-flex gap-2">
                                <a class="btn btn-outline-light px-4 py-2 fw-bold text-uppercase btn-sm" asp-area="Identity" asp-page="/Account/Login">Log In</a>
                                <a class="btn btn-danger px-4 py-2 fw-bold text-uppercase btn-sm" asp-area="Identity" asp-page="/Account/Register">Sign Up</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="@((bool?)ViewData["UseFullWidthLayout"] == true ? "" : "container py-5")">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer mt-auto py-4 bg-black border-top border-secondary border-opacity-25">
        <div class="container text-center">
            <div class="mb-2">
                <i class="bi bi-film text-danger fs-3"></i>
            </div>
            <span class="text-white-50 small text-uppercase" style="letter-spacing: 2px;">
                &copy; @DateTime.Now.Year OnlineCinema • Створено з пристрастю до кіно
            </span>
            <div class="mt-2">
                <a asp-controller="Home" asp-action="Privacy" class="text-secondary text-decoration-none small mx-2">Privacy</a>
                <a href="#" class="text-secondary text-decoration-none small mx-2">Terms of Service</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>